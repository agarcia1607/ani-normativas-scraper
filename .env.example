# .env.example — copiar a .env y completar
# Este archivo NO debe commitearse con valores reales.

# Airflow
AIRFLOW_UID=50000
AIRFLOW_GID=50000

# Base de datos (mismo Postgres del docker-compose)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=airflow
DB_USER=airflow
DB_PASSWORD=airflow

# Scraping
NUM_PAGES_TO_SCRAPE=9

# Validación
VALIDATION_RULES_PATH=/opt/airflow/configs/validation_rules.yaml
